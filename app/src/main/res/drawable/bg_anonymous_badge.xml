<?xml version="1.0" encoding="utf-8"?>
<!--
    初学者阅读提示：
    这是 bg_anonymous_badge 背景图形资源，通常定义圆角、描边、填充色或按压状态。
    布局文件通过 @drawable/名称 把它设置到控件背景上。
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/browser_control_pressed" />
            <corners android:radius="17dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/browser_control_pressed" />
            <corners android:radius="17dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/privacy_background" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</selector>
