<?xml version="1.0" encoding="utf-8"?>
<!--
    初学者阅读提示：
    这是 bg_wenxin_pill 背景图形资源，通常定义圆角、描边、填充色或按压状态。
    布局文件通过 @drawable/名称 把它设置到控件背景上。
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="45"
                android:startColor="@color/browser_wenxin_start"
                android:centerColor="@color/browser_wenxin_center"
                android:endColor="@color/browser_wenxin_end" />
            <corners android:radius="29dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="45"
                android:startColor="@color/browser_wenxin_start"
                android:centerColor="@color/browser_wenxin_center"
                android:endColor="@color/browser_wenxin_end" />
            <corners android:radius="29dp" />
        </shape>
    </item>
</selector>
