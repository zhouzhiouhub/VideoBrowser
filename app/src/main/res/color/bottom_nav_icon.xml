<?xml version="1.0" encoding="utf-8"?>
<!--
    初学者阅读提示：
    这是 bottom_nav_icon 颜色状态选择器，用于让同一个控件在普通、按下或不可用状态显示不同颜色。
    布局或图标通过 @color/名称 引用它。
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/browser_icon_disabled" android:state_enabled="false" />
    <item android:color="@color/browser_icon" />
</selector>
