<?xml version="1.0" encoding="utf-8"?>
<!--
    初学者阅读提示：
    这是主浏览器页面的静态骨架。顶部是地址栏，中间是网页 WebView 和搜索建议层，
    底部是导航工具栏；真正的点击逻辑、加载网页逻辑在 MainActivity 和 browser 模块里完成。
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/browser_background">

    <!-- 顶部工具栏承载地址输入、站点安全图标、搜索/打开按钮和功能入口。 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="78dp"
        android:background="@color/browser_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="10dp"
        android:paddingEnd="18dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 地址栏本身是一个横向容器，里面放搜索引擎标识、安全状态和可编辑输入框。 -->
        <LinearLayout
            android:id="@+id/addressBar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_address_bar"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/addressProviderBadge"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:includeFontPadding="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/siteSecurityIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:importantForAccessibility="yes"
                android:padding="2dp"
                android:scaleType="center"
                android:visibility="gone" />

            <EditText
                android:id="@+id/addressInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/hint_address_bar"
                android:imeOptions="actionSearch|flagNoExtractUi"
                android:includeFontPadding="false"
                android:inputType="textUri|textNoSuggestions"
                android:selectAllOnFocus="true"
                android:singleLine="true"
                android:textColor="@color/browser_text"
                android:textColorHint="@color/browser_text_hint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/loadButton"
                android:layout_width="74dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_address_go_button"
                android:clickable="true"
                android:contentDescription="@string/action_load_url"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/hint_address_bar"
                android:textColor="@color/browser_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/privateBrowsingBadge"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_anonymous_badge"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/anonymous_badge"
            android:textColor="@color/privacy_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/bookmarkButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_add_bookmark"
            android:enabled="false"
            android:padding="10dp"
            android:scaleType="center"
            android:src="@drawable/ic_star_24"
            android:tint="@color/bottom_nav_icon"
            android:visibility="gone" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/pageProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="@android:color/transparent"
        android:progressTint="@color/progress_active"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <LinearLayout
        android:id="@+id/addressSuggestionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/browser_surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pageProgress" />

    <HorizontalScrollView
        android:id="@+id/searchProviderScroll"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:background="@color/browser_background"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/addressSuggestionPanel">

        <LinearLayout
            android:id="@+id/searchProviderList"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/webview_background"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchProviderScroll">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="ifContentScrolls" />

    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="74dp"
        android:background="@color/browser_surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_back"
            android:enabled="false"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_arrow_back_24"
            android:tint="@color/bottom_nav_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/refreshButton"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/refreshButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_refresh"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_refresh_24"
            android:tint="@color/bottom_nav_icon"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/wenxinButton"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/wenxinButton"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_wenxin_pill"
            android:contentDescription="@string/action_wenxin"
            android:padding="15dp"
            android:scaleType="center"
            android:src="@drawable/ic_wenxin_wave_24"
            android:tint="@color/address_go_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/pageToolsButton"
            app:layout_constraintStart_toEndOf="@id/refreshButton"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/pageToolsButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/title_page_tools"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_menu_24"
            android:tint="@color/bottom_nav_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/profileButton"
            app:layout_constraintStart_toEndOf="@id/wenxinButton"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/profileButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_profile"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_settings_24"
            android:tint="@color/bottom_nav_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/pageToolsButton"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
