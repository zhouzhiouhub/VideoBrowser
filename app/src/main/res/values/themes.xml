<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        初学者阅读提示：
        主题决定状态栏、导航栏、强调色和是否使用系统 ActionBar。
        Manifest 中的 @style/Theme.VideoBrowser 会最终应用这里定义的外观。
    -->
    <style name="Base.Theme.VideoBrowser" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorAccent">@color/browser_primary</item>
        <item name="android:navigationBarColor">@color/browser_surface</item>
        <item name="android:statusBarColor">@color/browser_surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.VideoBrowser" parent="Base.Theme.VideoBrowser" />
</resources>
